{
  "tag": {
    "border-radius":  { "$value": "{border-radius.full}",    "$type": "dimension", "$description": "Pill shape" },
    "font-family":    { "$value": "{font-family.sans}",      "$type": "string",    "$description": "Font family" },
    "font-size":      { "$value": "{font-size.1}",           "$type": "dimension", "$description": "14px — UI label" },
    "font-weight":    { "$value": "{font-weight.medium}",    "$type": "number",    "$description": "Medium weight" },
    "line-height":    { "$value": "{line-height.none}",      "$type": "number",    "$description": "Single-line" },
    "padding-block":  { "$value": "{spacing.1}",             "$type": "dimension", "$description": "Block (vertical) padding" },
    "padding-inline": { "$value": "{spacing.3}",             "$type": "dimension", "$description": "Inline (horizontal) padding" },

    "default-bg":       { "$value": "{color.grey-lightest}",   "$type": "color", "$description": "Default background" },
    "default-color":    { "$value": "{color.text.on-light}",    "$type": "color", "$description": "Default text color" },
    "primary-bg":       { "$value": "{color.primary}",         "$type": "color", "$description": "Primary (prussian) background" },
    "primary-color":    { "$value": "{color.text.on-dark}",       "$type": "color", "$description": "Primary text — white on dark bg" },
    "accent-1-bg":     { "$value": "{color.accent-1}",       "$type": "color", "$description": "Accent 1 (lavender) background" },
    "accent-1-color":  { "$value": "{color.text.on-light}",    "$type": "color", "$description": "Accent 1 text — dark on light bg" },
    "accent-2-bg":      { "$value": "{color.accent-2}",        "$type": "color", "$description": "Accent 2 (yellow) background" },
    "accent-2-color":   { "$value": "{color.text.on-light}",    "$type": "color", "$description": "Accent 2 text — dark on light bg" },
    "support-1-bg":    { "$value": "{color.support-1}",      "$type": "color", "$description": "Support 1 (emerald) background" },
    "support-1-color": { "$value": "{color.text.on-light}",    "$type": "color", "$description": "Support 1 text — dark on light bg" },
    "support-2-bg":       { "$value": "{color.support-2}",         "$type": "color", "$description": "Support 2 (cayenne) background" },
    "support-2-color":    { "$value": "{color.text.on-light}",    "$type": "color", "$description": "Support 2 text — dark on orange bg" },

    "neutral-bg":    { "$value": "{color.grey-darkest}",  "$type": "color", "$description": "Neutral semantic — background (AAA ~8.9:1 with white text)" },
    "neutral-color": { "$value": "{color.white}",         "$type": "color", "$description": "Neutral semantic — white text on dark grey" },
    "info-bg":       { "$value": "{color.prussian}",      "$type": "color", "$description": "Info semantic — prussian background (AAA ~16.9:1 with white text)" },
    "info-color":    { "$value": "{color.white}",         "$type": "color", "$description": "Info semantic — white text on prussian" },
    "warning-bg":    { "$value": "{color.yellow}",        "$type": "color", "$description": "Warning semantic — brand yellow background (AAA ~10.3:1 with prussian text)" },
    "warning-color": { "$value": "{color.prussian}",      "$type": "color", "$description": "Warning semantic — prussian text on yellow" },
    "danger-bg":     { "$value": "{color.red-on-light}",  "$type": "color", "$description": "Danger semantic — brand red background (AAA ~7.2:1 with white text)" },
    "danger-color":  { "$value": "{color.white}",         "$type": "color", "$description": "Danger semantic — white text on red" }
  }
}
