{
  "org-switcher": {
    "logo-size":              { "$value": "2rem",                          "$type": "dimension", "$description": "Tamaño del cuadrado del logo/iniciales" },
    "logo-border-radius":     { "$value": "{border-radius.sm}",            "$type": "dimension", "$description": "Radio del logo/iniciales" },
    "initials-font-size":     { "$value": "{font-size.1}",                 "$type": "dimension", "$description": "Tamaño de texto de las iniciales" },
    "initials-font-weight":   { "$value": "{font-weight.medium}",          "$type": "number",    "$description": "Peso de las iniciales" },
    "initials-color":         { "$value": "{color.white}",                 "$type": "color",     "$description": "Color de texto de las iniciales" },
    "initials-bg":            { "$value": "{color.primary}",               "$type": "color",     "$description": "Fondo del cuadrado de iniciales" },
    "trigger-padding-block":  { "$value": "{spacing.2}",                   "$type": "dimension", "$description": "Padding vertical del trigger" },
    "trigger-padding-inline": { "$value": "{spacing.3}",                   "$type": "dimension", "$description": "Padding horizontal del trigger" },
    "trigger-gap":            { "$value": "{spacing.3}",                   "$type": "dimension", "$description": "Espacio entre logo y nombre" },
    "trigger-border-radius":  { "$value": "{border-radius.sm}",            "$type": "dimension", "$description": "Radio del trigger" },
    "trigger-hover-bg":       { "$value": "{color.grey-lightest}",         "$type": "color",     "$description": "Fondo del trigger al hover" },
    "name-font-size":         { "$value": "{font-size.2}",                 "$type": "dimension", "$description": "Tamaño de texto del nombre de la org" },
    "name-font-weight":       { "$value": "{font-weight.medium}",          "$type": "number",    "$description": "Peso del nombre de la org" },
    "name-color":             { "$value": "{color.text.on-light}",         "$type": "color",     "$description": "Color del nombre de la org" },
    "content-min-width":      { "$value": "14rem",                         "$type": "dimension", "$description": "Ancho mínimo del dropdown" },
    "content-bg":             { "$value": "{floating-panel.bg}",           "$type": "color",     "$description": "Fondo del panel" },
    "content-border-width":   { "$value": "{floating-panel.border-width}", "$type": "dimension", "$description": "Borde del panel" },
    "content-border-color":   { "$value": "{floating-panel.border-color}", "$type": "color",     "$description": "Color del borde del panel" },
    "content-border-radius":  { "$value": "{floating-panel.border-radius}","$type": "dimension", "$description": "Radio del panel" },
    "content-shadow":         { "$value": "{floating-panel.shadow}",       "$type": "shadow",    "$description": "Sombra del panel" },
    "content-z-index":        { "$value": "{floating-panel.z-index}",      "$type": "number",    "$description": "Z-index del dropdown (por encima del sidebar en mobile)" },
    "content-padding-block":  { "$value": "{spacing.2}",                   "$type": "dimension", "$description": "Padding vertical del panel" },
    "content-padding-inline": { "$value": "{spacing.2}",                   "$type": "dimension", "$description": "Padding horizontal del panel" },
    "item-padding-block":     { "$value": "{spacing.2}",                   "$type": "dimension", "$description": "Padding vertical de cada ítem" },
    "item-padding-inline":    { "$value": "{spacing.3}",                   "$type": "dimension", "$description": "Padding horizontal de cada ítem" },
    "item-border-radius":     { "$value": "{border-radius.sm}",            "$type": "dimension", "$description": "Radio de cada ítem" },
    "item-font-size":         { "$value": "{font-size.2}",                 "$type": "dimension", "$description": "Tamaño de texto de ítems" },
    "item-font-weight":       { "$value": "{font-weight.default}",         "$type": "number",    "$description": "Peso de ítems" },
    "item-color":             { "$value": "{color.text.on-light}",         "$type": "color",     "$description": "Color de ítems" },
    "item-hover-bg":          { "$value": "{color.grey-lightest}",         "$type": "color",     "$description": "Fondo de ítem al hover" },
    "item-active-bg":         { "$value": "{color.grey-lightest}",         "$type": "color",     "$description": "Fondo de ítem de org activa" },
    "item-active-color":      { "$value": "{color.primary}",               "$type": "color",     "$description": "Color de ítem de org activa" },
    "separator-color":        { "$value": "{color.grey-light}",            "$type": "color",     "$description": "Color del separador" },
    "separator-height":       { "$value": "{border-width.sm}",             "$type": "dimension", "$description": "Alto del separador" },
    "separator-margin-block": { "$value": "{spacing.2}",                   "$type": "dimension", "$description": "Margen vertical del separador" },
    "transition-duration":    { "$value": "{floating-panel.transition-duration}", "$type": "number",    "$description": "Duración de transición" },
    "transition-easing":      { "$value": "{floating-panel.transition-easing}",   "$type": "string",    "$description": "Easing de transición" }
  }
}
