{
  "dots-button": {
    "sm-size":              { "$value": "1.5rem",                     "$type": "dimension", "$description": "Tamaño total del botón — sm" },
    "md-size":              { "$value": "2rem",                       "$type": "dimension", "$description": "Tamaño total del botón — md" },
    "lg-size":              { "$value": "2.5rem",                     "$type": "dimension", "$description": "Tamaño total del botón — lg" },
    "dot-diameter":         { "$value": "0.25rem",                    "$type": "dimension", "$description": "Diámetro de cada punto" },
    "dot-gap":              { "$value": "0.1875rem",                  "$type": "dimension", "$description": "Espacio entre puntos" },
    "color":                { "$value": "{color.text.on-light}",      "$type": "color",     "$description": "Color de los puntos" },
    "bg":                   { "$value": "transparent",                "$type": "color",     "$description": "Fondo por defecto" },
    "hover-bg":             { "$value": "{color.grey-lightest}",      "$type": "color",     "$description": "Fondo al hacer hover" },
    "active-bg":            { "$value": "{color.grey-light}",         "$type": "color",     "$description": "Fondo al hacer active" },
    "border-radius":        { "$value": "{border-radius.full}",       "$type": "dimension", "$description": "Radio del botón" },
    "cursor":               { "$value": "pointer",                    "$type": "string",    "$description": "Cursor por defecto" },
    "disabled-color":       { "$value": "{color.grey-darkest}",       "$type": "color",     "$description": "Color de puntos deshabilitado" },
    "disabled-cursor":      { "$value": "not-allowed",                "$type": "string",    "$description": "Cursor deshabilitado" },
    "focus-ring-width":     { "$value": "{border-width.md}",          "$type": "dimension", "$description": "Grosor del focus ring" },
    "focus-ring-color":     { "$value": "{color.primary}",            "$type": "color",     "$description": "Color del focus ring" },
    "focus-ring-offset":    { "$value": "{border-width.md}",          "$type": "dimension", "$description": "Offset del focus ring" },
    "transition-duration":  { "$value": "{motion.duration.fast}",     "$type": "number",    "$description": "Duración de transición" },
    "transition-easing":    { "$value": "{motion.easing.default}",    "$type": "string",    "$description": "Easing de transición" }
  }
}
