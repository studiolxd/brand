{
  "calendar-roster": {
    "font-family":               { "$value": "{font-family.sans}",          "$type": "string",    "$description": "Familia tipográfica base" },

    "nav-color":                 { "$value": "{color.text.on-light}",        "$type": "color",     "$description": "Color de los botones prev/next" },
    "nav-hover-bg":              { "$value": "{color.grey-lightest}",        "$type": "color",     "$description": "Fondo hover de los botones de navegación" },
    "nav-disabled-color":        { "$value": "{color.grey-dark}",            "$type": "color",     "$description": "Color deshabilitado" },
    "nav-focus-ring-color":      { "$value": "{color.primary}",              "$type": "color",     "$description": "Focus ring de navegación" },
    "nav-focus-ring-width":      { "$value": "{border-width.md}",            "$type": "dimension", "$description": "Grosor del focus ring" },
    "nav-focus-ring-offset":     { "$value": "{border-width.sm}",            "$type": "dimension", "$description": "Separación del focus ring" },
    "nav-radius":                { "$value": "{border-radius.sm}",           "$type": "dimension", "$description": "Radio del botón de navegación" },

    "title-font-size":           { "$value": "{font-size.2}",                "$type": "dimension", "$description": "Tamaño del título del mes" },
    "title-font-weight":         { "$value": "{font-weight.medium}",           "$type": "number",    "$description": "Peso del título del mes" },
    "title-color":               { "$value": "{color.text.on-light}",        "$type": "color",     "$description": "Color del título del mes" },

    "border-color":              { "$value": "{color.grey-light}",           "$type": "color",     "$description": "Color de los bordes del grid" },
    "border-width":              { "$value": "{border-width.sm}",            "$type": "dimension", "$description": "Grosor de los bordes del grid" },

    "th-name-width":             { "$value": "10rem",                        "$type": "dimension", "$description": "Ancho de la columna de nombre" },
    "th-name-font-size":         { "$value": "{font-size.1}",                "$type": "dimension", "$description": "Tamaño del encabezado de nombre" },
    "th-name-font-weight":       { "$value": "{font-weight.medium}",           "$type": "number",    "$description": "Peso del encabezado de nombre" },
    "th-name-color":             { "$value": "{color.text.muted-on-light}",  "$type": "color",     "$description": "Color del encabezado de nombre" },
    "th-name-bg":                { "$value": "{color.background.light}",     "$type": "color",     "$description": "Fondo sticky de la columna de nombre" },
    "th-name-padding-block":     { "$value": "{spacing.2}",                  "$type": "dimension", "$description": "Padding vertical del encabezado de nombre" },
    "th-name-padding-inline":    { "$value": "{spacing.3}",                  "$type": "dimension", "$description": "Padding horizontal del encabezado de nombre" },

    "th-day-width":              { "$value": "2.5rem",                       "$type": "dimension", "$description": "Ancho mínimo de cada columna de día" },
    "th-day-font-size":          { "$value": "{font-size.1}",                "$type": "dimension", "$description": "Tamaño del número de día" },
    "th-day-sub-font-size":      { "$value": "0.625rem",                     "$type": "dimension", "$description": "Tamaño de la letra del día de semana" },
    "th-day-color":              { "$value": "{color.text.on-light}",        "$type": "color",     "$description": "Color del encabezado de día" },
    "th-day-padding-block":      { "$value": "{spacing.2}",                  "$type": "dimension", "$description": "Padding vertical del encabezado de día" },
    "th-day-bg":                 { "$value": "{color.background.light}",     "$type": "color",     "$description": "Fondo del encabezado de día" },

    "th-day-today-color":        { "$value": "{color.background.light}",     "$type": "color",     "$description": "Texto del encabezado del día de hoy" },
    "th-day-today-bg":           { "$value": "{color.primary}",              "$type": "color",     "$description": "Fondo del encabezado del día de hoy" },
    "th-day-today-radius":       { "$value": "{border-radius.sm}",           "$type": "dimension", "$description": "Radio del badge del día de hoy" },

    "td-name-font-size":         { "$value": "{font-size.1}",                "$type": "dimension", "$description": "Tamaño del nombre del empleado" },
    "td-name-color":             { "$value": "{color.text.on-light}",        "$type": "color",     "$description": "Color del nombre del empleado" },
    "td-name-bg":                { "$value": "{color.background.light}",     "$type": "color",     "$description": "Fondo sticky de la celda de nombre" },
    "td-name-padding-block":     { "$value": "{spacing.2}",                  "$type": "dimension", "$description": "Padding vertical de la celda de nombre" },
    "td-name-padding-inline":    { "$value": "{spacing.3}",                  "$type": "dimension", "$description": "Padding horizontal de la celda de nombre" },

    "cell-padding-block":        { "$value": "{spacing.1}",                  "$type": "dimension", "$description": "Padding vertical de las celdas de datos" },
    "cell-padding-inline":       { "$value": "{spacing.1}",                  "$type": "dimension", "$description": "Padding horizontal de las celdas de datos" },
    "cell-bg":                   { "$value": "{color.background.light}",     "$type": "color",     "$description": "Fondo de celdas de día laborable" },
    "cell-weekend-bg":           { "$value": "{color.grey-lightest}",        "$type": "color",     "$description": "Fondo de celdas de fin de semana" },
    "cell-holiday-bg":           { "$value": "#E5E7EB",                      "$type": "color",     "$description": "Fondo de celdas festivas" },
    "cell-non-working-bg":       { "$value": "{color.grey-lightest}",         "$type": "color",     "$description": "Fondo de celdas no laborables (laborable sin turno asignado)" },

    "schedule-font-size":        { "$value": "0.6875rem",                    "$type": "dimension", "$description": "Tamaño del texto de horario (11px)" },
    "schedule-color":            { "$value": "{color.text.on-light}",        "$type": "color",     "$description": "Color del texto de horario" },

    "chip-padding-block":        { "$value": "2px",                          "$type": "dimension", "$description": "Padding vertical del botón de navegación" },
    "chip-padding-inline":       { "$value": "{spacing.1}",                  "$type": "dimension", "$description": "Gap de la leyenda por item" },

    "legend-gap":                { "$value": "{spacing.3}",                  "$type": "dimension", "$description": "Gap entre elementos de la leyenda" },
    "legend-font-size":          { "$value": "{font-size.1}",                "$type": "dimension", "$description": "Tamaño del texto de la leyenda" },
    "legend-color":              { "$value": "{color.text.muted-on-light}",  "$type": "color",     "$description": "Color del texto de la leyenda" },
    "legend-swatch-size":        { "$value": "{spacing.3}",                  "$type": "dimension", "$description": "Tamaño del cuadradito de color en la leyenda" },
    "legend-swatch-radius":      { "$value": "{border-radius.sm}",           "$type": "dimension", "$description": "Radio del cuadradito de color" },

    "transition-duration":       { "$value": "{motion.duration.fast}",       "$type": "number",    "$description": "Duración de las transiciones" },
    "transition-easing":         { "$value": "{motion.easing.default}",      "$type": "string",    "$description": "Easing de las transiciones" }
  }
}
