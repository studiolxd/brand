{
  "select": {
    "border-radius":          { "$value": "{border-radius.none}",        "$type": "dimension", "$description": "Radio del borde del trigger" },
    "border-width":           { "$value": "{border-width.sm}",           "$type": "dimension", "$description": "Grosor del borde" },
    "border-style":           { "$value": "solid",                       "$type": "string",    "$description": "Estilo del borde" },
    "border-color":           { "$value": "{color.primary}",             "$type": "color",     "$description": "Color del borde" },
    "padding-block":          { "$value": "{control.padding-block}",     "$type": "dimension", "$description": "Padding block del trigger" },
    "padding-inline":         { "$value": "{control.padding-inline}",    "$type": "dimension", "$description": "Padding inline del trigger" },
    "font-family":            { "$value": "{font-family.sans}",          "$type": "string",    "$description": "Familia tipográfica" },
    "font-size":              { "$value": "{font-size.2}",               "$type": "dimension", "$description": "Tamaño de fuente" },
    "line-height":            { "$value": "{control.line-height}",       "$type": "number",    "$description": "Interlineado del trigger" },
    "font-weight":            { "$value": "{font-weight.default}",       "$type": "number",    "$description": "Peso tipográfico" },
    "color":                  { "$value": "{color.text.on-light}",        "$type": "color",     "$description": "Color del texto" },
    "bg":                     { "$value": "{color.white}",               "$type": "color",     "$description": "Fondo del trigger" },
    "icon-size":              { "$value": "0.625rem",                    "$type": "dimension", "$description": "Tamaño del chevron" },
    "icon-transition":        { "$value": "{motion.duration.fast}",      "$type": "number",    "$description": "Duración de la transición del icono" },
    "focus-ring-width":       { "$value": "{border-width.md}",           "$type": "dimension", "$description": "Grosor del anillo de foco" },
    "focus-ring-offset":      { "$value": "-3px",                        "$type": "dimension", "$description": "Offset del anillo de foco (negativo = inset)" },
    "focus-ring-color":       { "$value": "{color.primary}",             "$type": "color",     "$description": "Color del anillo de foco" },
    "content-bg":             { "$value": "{color.white}",               "$type": "color",     "$description": "Fondo del dropdown" },
    "content-border-color":   { "$value": "{color.primary}",             "$type": "color",     "$description": "Borde del dropdown" },
    "content-z-index":        { "$value": "1100",                        "$type": "number",    "$description": "Z-index del dropdown (por encima del header: 1001)" },
    "content-max-height":     { "$value": "var(--radix-select-content-available-height)", "$type": "string", "$description": "Altura máxima del dropdown (por defecto, el espacio disponible en viewport que expone Radix)" },
    "item-padding-block":     { "$value": "{spacing.2}",                 "$type": "dimension", "$description": "Padding block de cada opción" },
    "item-highlighted-bg":    { "$value": "{color.primary}",             "$type": "color",     "$description": "Fondo de opción resaltada" },
    "item-highlighted-color": { "$value": "{color.white}",               "$type": "color",     "$description": "Texto de opción resaltada" },
    "sm-font-size":           { "$value": "{font-size.1}",               "$type": "dimension", "$description": "Tamaño de fuente — variante sm (14px)" },
    "sm-padding-block":       { "$value": "{spacing.1}",                 "$type": "dimension", "$description": "Padding block del trigger — variante sm" },
    "sm-padding-inline":      { "$value": "{spacing.2}",                 "$type": "dimension", "$description": "Padding inline del trigger — variante sm" },
    "sm-item-padding-block":  { "$value": "{spacing.1}",                 "$type": "dimension", "$description": "Padding block de cada opción — variante sm" },
    "lg-font-size":           { "$value": "{font-size.3}",               "$type": "dimension", "$description": "Tamaño de fuente — variante lg (20px)" },
    "lg-padding-block":       { "$value": "{spacing.5}",                 "$type": "dimension", "$description": "Padding block del trigger — variante lg" },
    "lg-padding-inline":      { "$value": "{spacing.5}",                 "$type": "dimension", "$description": "Padding inline del trigger — variante lg" },
    "lg-item-padding-block":  { "$value": "{spacing.3}",                 "$type": "dimension", "$description": "Padding block de cada opción — variante lg" },
    "surface-dark-bg":                     { "$value": "{color.background.dark}", "$type": "color", "$description": "Fondo del trigger — surface-dark" },
    "surface-dark-color":                  { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Color del texto — surface-dark" },
    "surface-dark-border-color":           { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Color del borde — surface-dark" },
    "surface-dark-focus-ring-color":       { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Color del anillo de foco — surface-dark" },
    "surface-dark-content-bg":             { "$value": "{color.background.dark}", "$type": "color", "$description": "Fondo del dropdown — surface-dark" },
    "surface-dark-content-border-color":   { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Borde del dropdown — surface-dark" },
    "surface-dark-item-highlighted-bg":    { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Fondo de opción resaltada — surface-dark" },
    "surface-dark-item-highlighted-color": { "$value": "{color.background.dark}","$type": "color", "$description": "Texto de opción resaltada — surface-dark" }
  }
}
