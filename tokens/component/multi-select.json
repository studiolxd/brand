{
  "multi-select": {
    "border-radius":          { "$value": "{select.border-radius}",          "$type": "dimension", "$description": "Radio del borde del trigger" },
    "border-width":           { "$value": "{select.border-width}",           "$type": "dimension", "$description": "Grosor del borde" },
    "border-style":           { "$value": "{select.border-style}",           "$type": "string",    "$description": "Estilo del borde" },
    "border-color":           { "$value": "{select.border-color}",           "$type": "color",     "$description": "Color del borde" },
    "padding-block":          { "$value": "{select.padding-block}",          "$type": "dimension", "$description": "Padding block del trigger" },
    "padding-inline":         { "$value": "{select.padding-inline}",         "$type": "dimension", "$description": "Padding inline del trigger" },
    "font-family":            { "$value": "{select.font-family}",            "$type": "string",    "$description": "Familia tipográfica" },
    "font-size":              { "$value": "{select.font-size}",              "$type": "dimension", "$description": "Tamaño de fuente" },
    "line-height":            { "$value": "{select.line-height}",            "$type": "number",    "$description": "Interlineado del trigger" },
    "font-weight":            { "$value": "{select.font-weight}",            "$type": "number",    "$description": "Peso tipográfico" },
    "color":                  { "$value": "{select.color}",                  "$type": "color",     "$description": "Color del texto" },
    "placeholder-color":      { "$value": "{color.text.muted-on-light}",     "$type": "color",     "$description": "Color del placeholder" },
    "bg":                     { "$value": "{select.bg}",                     "$type": "color",     "$description": "Fondo del trigger" },
    "icon-size":              { "$value": "{select.icon-size}",              "$type": "dimension", "$description": "Tamaño del chevron" },
    "icon-transition":        { "$value": "{select.icon-transition}",        "$type": "number",    "$description": "Duración de la transición del icono" },
    "focus-ring-width":       { "$value": "{select.focus-ring-width}",       "$type": "dimension", "$description": "Grosor del anillo de foco" },
    "focus-ring-offset":      { "$value": "{select.focus-ring-offset}",      "$type": "dimension", "$description": "Offset del anillo de foco (negativo = inset)" },
    "focus-ring-color":       { "$value": "{select.focus-ring-color}",       "$type": "color",     "$description": "Color del anillo de foco" },
    "content-bg":             { "$value": "{select.content-bg}",             "$type": "color",     "$description": "Fondo del dropdown" },
    "content-border-color":   { "$value": "{select.content-border-color}",   "$type": "color",     "$description": "Borde del dropdown" },
    "content-z-index":        { "$value": "{select.content-z-index}",        "$type": "number",    "$description": "Z-index del dropdown" },
    "content-max-height":     { "$value": "var(--radix-popover-content-available-height)", "$type": "string", "$description": "Altura máxima del dropdown (por defecto, el espacio disponible en viewport que expone Radix)" },
    "item-padding-block":     { "$value": "{select.item-padding-block}",     "$type": "dimension", "$description": "Padding block de cada opción" },
    "item-highlighted-bg":    { "$value": "{select.item-highlighted-bg}",    "$type": "color",     "$description": "Fondo de opción en foco/hover" },
    "item-highlighted-color": { "$value": "{select.item-highlighted-color}", "$type": "color",     "$description": "Texto de opción en foco/hover" },
    "pill-bg":                { "$value": "{color.primary}",                 "$type": "color",     "$description": "Fondo de la pill de valor seleccionado" },
    "pill-color":             { "$value": "{color.white}",                   "$type": "color",     "$description": "Texto de la pill" },
    "pill-border-radius":     { "$value": "{border-radius.full}",            "$type": "dimension", "$description": "Radio de la pill" },
    "pill-padding-block":     { "$value": "{spacing.1}",                     "$type": "dimension", "$description": "Padding block de la pill" },
    "pill-padding-inline":    { "$value": "{spacing.2}",                     "$type": "dimension", "$description": "Padding inline de la pill" },
    "pill-gap":               { "$value": "{spacing.1}",                     "$type": "dimension", "$description": "Separación entre texto y botón × en la pill" },
    "pill-font-size":         { "$value": "{font-size.1}",                   "$type": "dimension", "$description": "Tamaño de fuente de la pill" },
    "values-gap":             { "$value": "{spacing.1}",                     "$type": "dimension", "$description": "Separación entre pills" },
    "sm-font-size":           { "$value": "{select.sm-font-size}",           "$type": "dimension", "$description": "Tamaño de fuente — variante sm" },
    "sm-padding-block":       { "$value": "{select.sm-padding-block}",       "$type": "dimension", "$description": "Padding block del trigger — variante sm" },
    "sm-padding-inline":      { "$value": "{select.sm-padding-inline}",      "$type": "dimension", "$description": "Padding inline del trigger — variante sm" },
    "sm-item-padding-block":  { "$value": "{select.sm-item-padding-block}",  "$type": "dimension", "$description": "Padding block de cada opción — variante sm" },
    "lg-font-size":           { "$value": "{select.lg-font-size}",           "$type": "dimension", "$description": "Tamaño de fuente — variante lg" },
    "lg-padding-block":       { "$value": "{select.lg-padding-block}",       "$type": "dimension", "$description": "Padding block del trigger — variante lg" },
    "lg-padding-inline":      { "$value": "{select.lg-padding-inline}",      "$type": "dimension", "$description": "Padding inline del trigger — variante lg" },
    "lg-item-padding-block":  { "$value": "{select.lg-item-padding-block}",  "$type": "dimension", "$description": "Padding block de cada opción — variante lg" },
    "surface-dark-bg":                     { "$value": "{color.background.dark}", "$type": "color", "$description": "Background — surface-dark" },
    "surface-dark-color":                  { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Text color — surface-dark" },
    "surface-dark-border-color":           { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Border color — surface-dark" },
    "surface-dark-focus-ring-color":       { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Focus ring color — surface-dark" },
    "surface-dark-placeholder-color":      { "$value": "{color.text.muted-on-dark}", "$type": "color", "$description": "Placeholder color — surface-dark" },
    "surface-dark-content-bg":             { "$value": "{color.background.dark}", "$type": "color", "$description": "Dropdown background — surface-dark" },
    "surface-dark-content-border-color":   { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Dropdown border color — surface-dark" },
    "surface-dark-item-highlighted-bg":    { "$value": "{color.text.on-dark}",    "$type": "color", "$description": "Highlighted item background — surface-dark" },
    "surface-dark-item-highlighted-color": { "$value": "{color.background.dark}","$type": "color", "$description": "Highlighted item text — surface-dark" }
  }
}
