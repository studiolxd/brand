{
  "textarea": {
    "border-radius":                    { "$value": "{border-radius.none}",      "$type": "dimension", "$description": "Border radius" },
    "border-width":                     { "$value": "{border-width.sm}",         "$type": "dimension", "$description": "Border width" },
    "border-style":                     { "$value": "solid",                     "$type": "string",    "$description": "Border style" },
    "width":                            { "$value": "100%",                      "$type": "string",    "$description": "Textarea is always full width" },
    "padding-block":                    { "$value": "{control.padding-block}",   "$type": "dimension", "$description": "Block (vertical) padding" },
    "padding-inline":                   { "$value": "{control.padding-inline}",  "$type": "dimension", "$description": "Inline (horizontal) padding" },
    "font-family":                      { "$value": "{font-family.sans}",        "$type": "string",    "$description": "Font family" },
    "font-size":                        { "$value": "{font-size.3}",             "$type": "dimension", "$description": "Font size" },
    "font-weight":                      { "$value": "{font-weight.default}",     "$type": "number",    "$description": "Font weight" },
    "line-height":                      { "$value": "{line-height.normal}",      "$type": "number",    "$description": "Line height" },
    "min-height":                        { "$value": "15rem",                     "$type": "dimension", "$description": "15rem (240px) — altura mínima del textarea" },
    "resize":                           { "$value": "vertical",                  "$type": "string",    "$description": "Resize direction" },
    "cursor":                           { "$value": "text",                      "$type": "string",    "$description": "Cursor" },
    "transition-duration":              { "$value": "{motion.duration.fast}",    "$type": "number",    "$description": "Transition duration" },
    "transition-easing":                { "$value": "{motion.easing.default}",   "$type": "string",    "$description": "Transition easing" },
    "bg":                               { "$value": "{color.white}",             "$type": "color",     "$description": "Background" },
    "color":                            { "$value": "{color.text.default}",      "$type": "color",     "$description": "Text color" },
    "border-color":                     { "$value": "{color.primary}",           "$type": "color",     "$description": "Border color" },
    "placeholder-color":                { "$value": "{color.text.placeholder}",  "$type": "color",     "$description": "Placeholder text color" },
    "placeholder-text-transform":       { "$value": "uppercase",                 "$type": "string",    "$description": "Placeholder text transform" },
    "focus-border-color":               { "$value": "{color.primary}",           "$type": "color",     "$description": "Border color on focus" },
    "focus-ring-width":                 { "$value": "{control.focus-ring-width}", "$type": "dimension", "$description": "Focus ring width" },
    "focus-ring-inset-offset":          { "$value": "{border-width.sm}",         "$type": "dimension", "$description": "Gap between border and focus ring" },
    "focus-ring-color":                 { "$value": "{color.primary}",           "$type": "color",     "$description": "Focus ring color" },
    "disabled-cursor":                  { "$value": "not-allowed",               "$type": "string",    "$description": "Cursor when disabled" },
    "disabled-bg":                      { "$value": "{color.grey-lightest}",     "$type": "color",     "$description": "Background when disabled" },
    "disabled-color":                   { "$value": "{color.grey-darkest}",      "$type": "color",     "$description": "Text color when disabled" },
    "disabled-border-color":            { "$value": "{color.grey-light}",        "$type": "color",     "$description": "Border color when disabled" },
    "error-bg":                         { "$value": "{color.white}",             "$type": "color",     "$description": "Error background" },
    "error-color":                      { "$value": "{color.text.default}",      "$type": "color",     "$description": "Error text color" },
    "error-border-color":               { "$value": "{color.primary}",           "$type": "color",     "$description": "Error border color" },
    "error-placeholder-color":          { "$value": "{color.text.placeholder}",  "$type": "color",     "$description": "Error placeholder color" },
    "error-placeholder-text-transform": { "$value": "uppercase",                 "$type": "string",    "$description": "Error placeholder text transform" },
    "error-focus-border-color":         { "$value": "{color.primary}",           "$type": "color",     "$description": "Error border color on focus" },
    "error-focus-ring-color":           { "$value": "{color.error}",             "$type": "color",     "$description": "Error focus ring color" }
  }
}
