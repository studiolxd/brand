{
  "header": {
    "height-mobile":                   { "$value": "80px",                       "$type": "dimension", "$description": "Alto del header en mobile (con hamburger)" },
    "height-desktop":                  { "$value": "100px",                      "$type": "dimension", "$description": "Alto del header en desktop (nav inline)" },
    "logo-height-mobile":              { "$value": "60px",                       "$type": "dimension", "$description": "Alto del logo en mobile" },
    "logo-height-desktop":             { "$value": "60px",                       "$type": "dimension", "$description": "Alto del logo en desktop" },
    "bg":                              { "$value": "{color.background.default}",  "$type": "color",     "$description": "Fondo del header" },
    "dark-bg":                         { "$value": "{color.background.dark}",     "$type": "color",     "$description": "Fondo del header en variante oscura" },
    "shadow":                          { "$value": "{shadow.lg}",                 "$type": "shadow",    "$description": "Sombra del header" },
    "z-index":                         { "$value": "1000",                        "$type": "number",    "$description": "Z-index del header" },
    "controls-z-index":                { "$value": "1001",                        "$type": "number",    "$description": "Z-index del logo y hamburger (sobre el backdrop)" },
    "navbar-z-index":                  { "$value": "998",                         "$type": "number",    "$description": "Z-index del overlay de navegación" },
    "backdrop-z-index":                { "$value": "999",                         "$type": "number",    "$description": "Z-index del pseudo-elemento backdrop" },
    "navbar-transition-duration":      { "$value": "{motion.duration.base}",      "$type": "number",    "$description": "Duración del slide de la navbar" },
    "navbar-transition-easing":        { "$value": "{motion.easing.in-out}",      "$type": "string",    "$description": "Easing del slide de la navbar" },
    "nav-font-size-mobile":            { "$value": "{font-size.6}",               "$type": "dimension", "$description": "Tamaño de fuente de los enlaces en mobile" },
    "nav-font-size-desktop":           { "$value": "{font-size.2}",               "$type": "dimension", "$description": "Tamaño de fuente de los enlaces en desktop" },
    "nav-font-weight-mobile":          { "$value": "{font-weight.semibold}",       "$type": "number",    "$description": "Peso de fuente de los enlaces en mobile" },
    "nav-font-weight-desktop":         { "$value": "{font-weight.medium}",         "$type": "number",    "$description": "Peso de fuente de los enlaces en desktop" },
    "nav-color":                       { "$value": "{color.text.default}",         "$type": "color",     "$description": "Color de los enlaces de navegación" },
    "nav-dark-color":                  { "$value": "{color.text.dark}",            "$type": "color",     "$description": "Color de los enlaces en variante oscura" },
    "nav-gap-mobile":                  { "$value": "0",                            "$type": "dimension", "$description": "Separación entre enlaces en mobile" },
    "nav-padding-block-mobile":        { "$value": "{spacing.3}",                  "$type": "dimension", "$description": "Padding vertical de la zona de nav en mobile" },
    "nav-gap-desktop":                 { "$value": "{spacing.6}",                  "$type": "dimension", "$description": "Separación entre enlaces en desktop" },
    "nav-padding-inline":              { "$value": "{spacing.6}",                  "$type": "dimension", "$description": "Padding horizontal del header y la navbar" },
    "featured-border-width":           { "$value": "{border-width.sm}",            "$type": "dimension", "$description": "Grosor del borde del featured link" },
    "featured-border-color":           { "$value": "currentColor",                 "$type": "color",     "$description": "Color del borde del featured link" },
    "featured-font-size":              { "$value": "{font-size.5}",                "$type": "dimension", "$description": "Tamaño de fuente del featured link" },
    "featured-font-weight":            { "$value": "{font-weight.semibold}",        "$type": "number",    "$description": "Peso de fuente del featured link" },
    "featured-padding-inline":         { "$value": "{spacing.7}",                  "$type": "dimension", "$description": "Padding horizontal del featured link" },
    "featured-margin-inline-end":      { "$value": "{spacing.7}",                  "$type": "dimension", "$description": "Separación entre el featured link y la navegación" }
  }
}
