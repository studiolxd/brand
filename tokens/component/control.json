{
  "control": {
    "border-style":          { "$value": "solid",                          "$type": "string",    "$description": "Estilo del borde" },
    "border-radius":         { "$value": "{border-radius.none}",           "$type": "dimension", "$description": "Radio del borde" },
    "border-width":          { "$value": "{border-width.sm}",              "$type": "dimension", "$description": "Grosor del borde" },
    "height":                { "$value": "{size-component.md}",            "$type": "dimension", "$description": "Altura del control" },
    "font-family":           { "$value": "{font-family.sans}",             "$type": "string",    "$description": "Familia tipográfica" },
    "font-size":             { "$value": "{font-size.3}",                  "$type": "dimension", "$description": "Tamaño de fuente" },
    "font-weight":           { "$value": "{font-weight.default}",          "$type": "number",    "$description": "Peso tipográfico" },
    "line-height":           { "$value": "{line-height.none}",             "$type": "number",    "$description": "Interlineado" },
    "cursor":                { "$value": "text",                           "$type": "string",    "$description": "Cursor por defecto" },
    "disabled-cursor":       { "$value": "not-allowed",                    "$type": "string",    "$description": "Cursor cuando está deshabilitado" },
    "transition-duration":   { "$value": "{motion.duration.fast}",         "$type": "number",    "$description": "Duración de la transición" },
    "transition-easing":     { "$value": "{motion.easing.default}",        "$type": "string",    "$description": "Curva de animación" },
    "focus-ring-width":      { "$value": "{border-width.md}",              "$type": "dimension", "$description": "Grosor del anillo de foco" },
    "focus-ring-inset-offset": { "$value": "{border-width.sm}",            "$type": "dimension", "$description": "Separación entre borde y anillo de foco" },
    "padding-inline":        { "$value": "{spacing.4}",                    "$type": "dimension", "$description": "Padding inline — compartido por controles y elementos de formulario" },
    "padding-block":         { "$value": "{spacing.4}",                    "$type": "dimension", "$description": "Padding block — compartido por controles y elementos de formulario" }
  }
}
