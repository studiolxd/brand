{
  "kbd": {
    "min-size":       { "$value": "1.75rem",               "$type": "dimension", "$description": "Tamaño mínimo (28px) — mantiene las teclas de un solo carácter casi cuadradas" },
    "border-radius":  { "$value": "{border-radius.sm}",    "$type": "dimension", "$description": "Esquinas suaves de keycap (4px)" },
    "border-width":   { "$value": "{border-width.sm}",     "$type": "dimension", "$description": "Grosor del borde" },
    "border-color":   { "$value": "{color.grey-light}",    "$type": "color",     "$description": "Borde del keycap" },
    "bg":             { "$value": "{color.grey-lightest}", "$type": "color",     "$description": "Fondo del keycap" },
    "color":          { "$value": "{color.text.on-light}", "$type": "color",     "$description": "Color del símbolo de la tecla" },
    "shadow":         { "$value": "{shadow.sm}",           "$type": "shadow",    "$description": "Sombra sutil que da profundidad de tecla física" },
    "font-family":    { "$value": "{font-family.mono}",    "$type": "string",    "$description": "Monoespaciada (Google Sans Code) — alineada con contenido técnico" },
    "font-size":      { "$value": "{font-size.2}",         "$type": "dimension", "$description": "16px — tamaño md (por defecto)" },
    "font-weight":    { "$value": "{font-weight.medium}",  "$type": "number",    "$description": "Peso medio para legibilidad en tamaño compacto" },
    "line-height":    { "$value": "{line-height.none}",    "$type": "number",    "$description": "Sin interlineado extra — centrado por flexbox" },
    "padding-block":  { "$value": "{spacing.1}",           "$type": "dimension", "$description": "Padding vertical (4px)" },
    "padding-inline": { "$value": "{spacing.3}",           "$type": "dimension", "$description": "Padding horizontal (12px)" },

    "sm-min-size":       { "$value": "1.5rem",             "$type": "dimension", "$description": "Tamaño mínimo sm (24px)" },
    "sm-font-size":      { "$value": "{font-size.1}",      "$type": "dimension", "$description": "14px — tamaño sm" },
    "sm-padding-block":  { "$value": "{spacing.1}",        "$type": "dimension", "$description": "Padding vertical sm (4px)" },
    "sm-padding-inline": { "$value": "{spacing.2}",        "$type": "dimension", "$description": "Padding horizontal sm (8px)" },

    "lg-min-size":       { "$value": "2.25rem",            "$type": "dimension", "$description": "Tamaño mínimo lg (36px)" },
    "lg-font-size":      { "$value": "{font-size.2}",      "$type": "dimension", "$description": "18px — tamaño lg" },
    "lg-padding-block":  { "$value": "{spacing.2}",        "$type": "dimension", "$description": "Padding vertical lg (8px)" },
    "lg-padding-inline": { "$value": "{spacing.4}",        "$type": "dimension", "$description": "Padding horizontal lg (16px)" }
  }
}
