{
  "floating-panel": {
    "bg":                  { "$value": "{color.background.light}", "$type": "color",     "$description": "Fondo de cualquier panel flotante (popover, context-menu…)" },
    "border-width":        { "$value": "{border-width.sm}",        "$type": "dimension", "$description": "Grosor del borde" },
    "border-color":        { "$value": "{color.grey-light}",       "$type": "color",     "$description": "Color del borde" },
    "border-radius":       { "$value": "{border-radius.lg}",       "$type": "dimension", "$description": "Radio de las esquinas" },
    "shadow":              { "$value": "{shadow.md}",              "$type": "shadow",    "$description": "Sombra" },
    "z-index":             { "$value": "50",                       "$type": "number",    "$description": "Capa z" },
    "transition-duration": { "$value": "{motion.duration.fast}",   "$type": "number",    "$description": "Duración de la animación de entrada/salida" },
    "transition-easing":   { "$value": "{motion.easing.default}",  "$type": "string",    "$description": "Easing de la animación" }
  }
}
