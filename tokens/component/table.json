{
  "table": {
    "font-family":         { "$value": "{font-family.sans}",          "$type": "string",    "$description": "Font family" },
    "font-size":           { "$value": "{font-size.3}",               "$type": "dimension", "$description": "18px — Body default size" },
    "font-weight":         { "$value": "{font-weight.default}",       "$type": "number",    "$description": "Font weight base" },
    "line-height":         { "$value": "{line-height.normal}",        "$type": "number",    "$description": "Normal line height para celdas multilínea" },
    "color":               { "$value": "{color.text.on-light}",       "$type": "color",     "$description": "Color de texto base" },
    "bg":                  { "$value": "transparent",                 "$type": "color",     "$description": "Fondo de la tabla" },

    "border-width":        { "$value": "{border-width.sm}",           "$type": "dimension", "$description": "Grosor de separadores de fila" },
    "border-color":        { "$value": "{color.grey-light}",          "$type": "color",     "$description": "Color de separadores de fila" },

    "header-padding-block":   { "$value": "{spacing.3}",              "$type": "dimension", "$description": "Padding block del encabezado" },
    "header-padding-inline":  { "$value": "{spacing.3}",              "$type": "dimension", "$description": "Padding inline del encabezado" },
    "header-font-weight":     { "$value": "{font-weight.semibold}",   "$type": "number",    "$description": "Peso tipográfico del encabezado" },
    "header-border-width":    { "$value": "{border-width.md}",        "$type": "dimension", "$description": "Borde inferior del thead — más grueso que los separadores" },
    "header-border-color":    { "$value": "{color.text.on-light}",    "$type": "color",     "$description": "Color del borde inferior del thead" },
    "header-hover-bg":        { "$value": "{color.grey-lightest}",    "$type": "color",     "$description": "Fondo en hover de columna sortable" },

    "sort-icon-color":         { "$value": "{color.grey-dark}",       "$type": "color",     "$description": "Color del icono de sort inactivo" },
    "sort-icon-active-color":  { "$value": "{color.primary}",         "$type": "color",     "$description": "Color del icono de sort activo" },
    "sort-icon-inactive-opacity": { "$value": "0.35",                 "$type": "number",    "$description": "Opacidad del icono de sort cuando sortable pero sin sort activo" },

    "cell-padding-block":     { "$value": "{spacing.3}",              "$type": "dimension", "$description": "Padding block de celda" },
    "cell-padding-inline":    { "$value": "{spacing.3}",              "$type": "dimension", "$description": "Padding inline de celda" },

    "row-border-color":       { "$value": "{color.grey-light}",       "$type": "color",     "$description": "Color del separador entre filas" },
    "row-hover-bg":           { "$value": "{color.grey-lightest}",    "$type": "color",     "$description": "Fondo de fila interactiva en hover" },

    "focus-ring-color":       { "$value": "{color.primary}",          "$type": "color",     "$description": "Color del focus ring" },
    "focus-ring-width":       { "$value": "{border-width.md}",        "$type": "dimension", "$description": "Grosor del focus ring" },
    "focus-ring-offset":      { "$value": "{border-width.sm}",        "$type": "dimension", "$description": "Separación del focus ring" },

    "transition-duration":    { "$value": "{motion.duration.fast}",   "$type": "number",    "$description": "Duración de transiciones de hover" },
    "transition-easing":      { "$value": "{motion.easing.default}",  "$type": "string",    "$description": "Easing de transiciones" },

    "sm-font-size":             { "$value": "{font-size.1}",            "$type": "dimension", "$description": "14px — UI label size — variante sm" },
    "sm-header-padding-block":  { "$value": "{spacing.2}",            "$type": "dimension", "$description": "Padding block del encabezado — variante sm" },
    "sm-header-padding-inline": { "$value": "{spacing.2}",            "$type": "dimension", "$description": "Padding inline del encabezado — variante sm" },
    "sm-cell-padding-block":    { "$value": "{spacing.2}",            "$type": "dimension", "$description": "Padding block de celda — variante sm" },
    "sm-cell-padding-inline":   { "$value": "{spacing.2}",            "$type": "dimension", "$description": "Padding inline de celda — variante sm" }
  }
}
