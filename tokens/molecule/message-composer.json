{
  "message-composer": {
    "gap":            { "$value": "{spacing.2}",           "$type": "dimension", "$description": "Separación entre textarea y botón" },
    "padding-block":  { "$value": "{spacing.3}",           "$type": "dimension", "$description": "Padding vertical del contenedor" },
    "padding-inline": { "$value": "{spacing.4}",           "$type": "dimension", "$description": "Padding horizontal del contenedor" },
    "border-radius":  { "$value": "{textarea.border-radius}", "$type": "dimension", "$description": "Radio del contenedor — cascada desde textarea" },
    "border-color":   { "$value": "{textarea.border-color}", "$type": "color",     "$description": "Color del borde — cascada desde textarea" },
    "bg":             { "$value": "{textarea.bg}",          "$type": "color",     "$description": "Fondo del composer — cascada desde textarea" }
  }
}
