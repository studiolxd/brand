{
  "color": {
    "text": {
      "on-light":     { "$value": "{color.prussian}",      "$type": "color", "$description": "Text color for light backgrounds" },
      "on-dark":      { "$value": "{color.white}",         "$type": "color", "$description": "Text color for dark backgrounds" },
      "placeholder":  { "$value": "{color.grey-dark}",     "$type": "color", "$description": "Placeholder text color" },
      "muted-on-light": { "$value": "{color.grey-darkest}", "$type": "color", "$description": "Muted text — helper text, secondary labels" },
      "muted-on-dark":  { "$value": "{color.grey-light}",  "$type": "color", "$description": "Muted text on dark backgrounds" }
    },
    "background": {
      "light": { "$value": "{color.white}",    "$type": "color", "$description": "Light surface background" },
      "dark":  { "$value": "{color.prussian}", "$type": "color", "$description": "Dark surface background" }
    }
  }
}
